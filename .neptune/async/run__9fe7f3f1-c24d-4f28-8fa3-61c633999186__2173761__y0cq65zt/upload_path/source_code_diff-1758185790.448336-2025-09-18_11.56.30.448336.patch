+def check_collapse(embeddings, similarity_matrix, model, name="emb", eps=1e-6, cross_entropy=None, target_entropy=None, kl_divs=None):
+    """
+    Check whether embeddings are collapsing and log metrics.
+    embeddings: [N, D] normalized embeddings (already normalized by F.normalize)
+    similarity_matrix: [N, N] pre-computed similarity matrix (embeddings @ embeddings.T)
+    model: PyTorch Lightning model instance for logging
+    name: prefix for logged metrics
+    cross_entropy: [N] pre-computed cross-entropy values (required)
+    target_entropy: [N] pre-computed target entropy values (required)
+    kl_divs: [N] pre-computed KL divergence values (required)
+    """
+    with torch.no_grad():
+        # 1. Variance per dimension (most important for collapse detection)
+        var_per_dim = embeddings.var(dim=0)
+        mean_var, min_var = var_per_dim.mean().item(), var_per_dim.min().item()
+
+        # 2. Reuse pre-computed similarity matrix
+        off_diag = similarity_matrix[~torch.eye(similarity_matrix.size(0), dtype=bool, device=embeddings.device)]
+        mean_sim_offdiag, std_sim_offdiag = off_diag.mean().item(), off_diag.std().item()
+        
+        # 3. Diagonal similarity (should be ~1.0 for normalized embeddings)
+        diag = torch.diag(similarity_matrix)
+        mean_sim_diag, std_sim_diag = diag.mean().item(), diag.std().item()
+        
+        # 4. Cross-entropy decomposition: H(YY, XY) = h(YY) + DKL(YY || XY)
+        
+        # Use pre-computed values from forward loss computation
+        mean_cross_entropy = cross_entropy.mean().item()
+        mean_target_entropy = target_entropy.mean().item()
+        mean_kl_div = kl_divs.mean().item()
+        std_kl_div = kl_divs.std().item()
+       
+        # Enhanced collapse detection using multiple criteria
+        # KL divergence is the key metric - KL ≈ 0 indicates collapse (distributions are identical)
+        collapsed = (mean_var < eps) or (mean_sim_offdiag > 0.8) or (mean_kl_div < 0.1)
+
+        # Create log dictionary and log all metrics
+        log_dict = {
+            f"{name}_mean_var": mean_var,
+            f"{name}_min_var": min_var,
+            f"{name}_mean_sim_offdiag": mean_sim_offdiag,
+            f"{name}_std_sim_offdiag": std_sim_offdiag,
+            f"{name}_mean_sim_diag": mean_sim_diag,
+            f"{name}_std_sim_diag": std_sim_diag,
+            f"{name}_mean_cross_entropy": mean_cross_entropy,
+            f"{name}_mean_target_entropy": mean_target_entropy,
+            f"{name}_mean_kl_div": mean_kl_div,
+            f"{name}_std_kl_div": std_kl_div,
+            f"{name}_collapsed": float(collapsed),
+            f"{name}_collapse_warning": 1.0 if collapsed else 0.0,
+        }
+        
+        # Log all metrics using the same structure as the rest of the codebase
+        for k, v in log_dict.items():
+            model.log(k, v, on_step=False, on_epoch=True)
