+        logits_YY = torch.matmul(emb_c, emb_c.T)  # [total_conditions, total_conditions]
+        
+        # Compute YY distribution and its log separately for clarity
+        # Apply stop gradient trick conditionally to prevent collapse
+        if self.gradient_stop:
+            YY = F.softmax((logits_YY * scale_momentum).detach(), dim=1)  # Use momentum temperature for targets
+            log_YY = F.log_softmax((logits_YY * scale_momentum).detach(), dim=1)  # Use momentum temperature for targets
+        else:
+            YY = F.softmax(logits_YY * scale_momentum, dim=1)  # Use momentum temperature for targets
+            log_YY = F.log_softmax(logits_YY * scale_momentum, dim=1)  # Use momentum temperature for targets
+        
+        # Cross-entropy decomposition: H(YY, XY) = h(YY) + DKL(YY || XY)
+        cross_entropy = -(YY * logp_XY).sum(dim=1)  # [total_conditions] - H(YY, XY)
+        target_entropy = -(YY * log_YY).sum(dim=1)  # [total_conditions] - h(YY) = -sum(YY * log(YY))
+        kl_divs = cross_entropy - target_entropy  # [total_conditions] - DKL(YY || XY)
